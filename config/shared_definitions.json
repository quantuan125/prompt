{
  "_description": "Shared enums and constants used across all roles",
  
  "roles": [
    "consultant",
    "planner", 
    "developer",
    "reviewer"
  ],
  
  "artifact_types": {
    "consultation": {
      "prefix": "consultation",
      "purpose": "Architectural analysis and recommendations"
    },
    "plan": {
      "prefix": "plan",
      "purpose": "Detailed development instructions"
    },
    "devnotes": {
      "prefix": "devnotes",
      "purpose": "Implementation report and code changes"
    },
    "review": {
      "prefix": "review",
      "purpose": "Quality assurance and compliance check"
    }
  },
  
  "workflow_phases": [
    "consultation",
    "planning",
    "development",
    "review",
    "completed"
  ],
  
  "statuses": {
