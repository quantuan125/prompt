    "ready_for_review": "Completed and ready for human review",
    "in_progress": "Currently being worked on",
    "completed": "Finished and approved",
    "blocked": "Cannot proceed due to issues"
  },
  
  "review_verdicts": {
    "approved": "Implementation meets all requirements",
    "conditional_approval": "Minor issues that don't block progress",
    "rejected": "Major issues requiring rework"
  },
  
  "change_types": {
    "breaking": "Incompatible changes requiring major version",
    "feature": "New functionality requiring minor version",
    "patch": "Bug fixes or minor improvements"
